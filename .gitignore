# Secrets — `.env.example` is checked in, real `.env` never is.
.env

# Python build / cache artifacts.
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.pytest_cache/

# uv virtualenv.
.venv/

# Claude Code: personal/local overrides only. settings.json (shared) is fine to commit.
.claude/settings.local.json

# CLAUDE.md is the project-targeted Claude guidance — working agreements,
# phase discipline, lessons-learned. Local-only. The public README has
# the factual project shape.
CLAUDE.md

# Real, unsanitized email samples live locally only. Sanitized versions
# (without `-real` in the filename) are fair game to commit.
samples/emails/*-real.eml

# Same rule for the eval dataset: real rows stay local.
evals/dataset-real.jsonl

# Per-row eval results carry the agent's raw text output (recruiter names,
# reasoning over real email content). Only the aggregate scorecard `.json`
# files in evals/results/ commit. The `.rows.jsonl` companions stay local.
evals/results/*.rows.jsonl

# Phase 3.3 queued proposals contain the email hash and full proposal data,
# including real recruiter / application identifiers. Stay local.
pending_actions/

# Phase 3.5 audit log. Email *bodies* are hashed, but the proposal's
# reasoning text may still name real people / companies. Local-only;
# Phase 4 will tee this to a hosted aggregator with whatever redaction
# that destination requires.
audit/

# Editor / OS detritus.
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
